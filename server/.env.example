# Copy to .env and fill in.
# Local Postgres example:
#   DATABASE_URL=postgres://postgres:password@localhost:5432/faang_prep
#   PGSSL=disable
# Hosted (Neon / Supabase / Render) — they give you a connection string with sslmode=require:
#   DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

DATABASE_URL=
# Set PGSSL=disable ONLY for a local Postgres without SSL. Leave unset for hosted DBs.
PGSSL=
PORT=4000
